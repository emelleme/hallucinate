{
  "name": "club",
  "version": "0.0.0",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "concurrently -n web,app -c cyan,yellow \"bun run dev:web\" \"bun run dev:app\"",
    "dev:web": "vite",
    "dev:app": "bun --watch --no-clear-screen server.ts",
    "build": "tsc && vite build",
    "pack:assets": "bun scripts/pack-assimp-assets.ts",
    "start": "bun server.ts",
    "preview": "vite preview",
    "pages:dev": "npx wrangler pages dev ./dist",
    "pages:deploy": "npx wrangler pages deploy ./dist"
  },
  "dependencies": {
    "@napi-rs/canvas": "^1.0.0",
    "ably": "^2.22.1",
    "assimpjs": "^0.0.10",
    "uplot": "^1.6.32"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.0",
    "@types/bun": "^1.3.14",
    "concurrently": "^9.2.1",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.14"
  }
}
